# ============================================
# VIJAYA DENTAL CLINIC - .gitignore
# React + Node.js Project
# ============================================

# ============================================
# DEPENDENCIES (Never commit these)
# ============================================
node_modules/
/.pnp
.pnp.js
.pnp.loader.mjs

# ============================================
# PRODUCTION BUILDS (Generated automatically)
# ============================================
/build
/dist
/out

# ============================================
# ENVIRONMENT FILES (Contains secrets/keys)
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ============================================
# LOG FILES (Generated by npm/yarn)
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================
# OPERATING SYSTEM FILES (Not needed in repo)
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# IDE / EDITOR FILES (Personal settings)
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ============================================
# TESTING (Generated during test runs)
# ============================================
/coverage
/.nyc_output

# ============================================
# CACHE FILES (Can be regenerated)
# ============================================
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
*.tsbuildinfo
rollup.config-*.js

# ============================================
# OPTIONAL APP CHECKS (If used)
# ============================================
# Check the FAQ: https://github.com/facebook/create-react-app/blob/main/packages/react-scripts/template/README.md#npm-run-build-fails-to-minify
# .flowconfig
# flow-typed/

# ============================================
# YARN SPECIFIC (If using Yarn instead of npm)
# ============================================
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================
# MISCELLANEOUS
# ============================================
*.log
*.pid
*.seed
*.pid.lock
lib-cov
*.lcov
.nyc_output
grunt.js
*.bak
*.tmp
*.temp
.cache
.parcel-cache

# ============================================
# NEVER COMMIT SENSITIVE DATA
# ============================================
# *.pem (SSL certificates)
# *.key (Private keys)
# *.cert (Certificates)
# secrets.json
# firebase-config.json
# Any file containing API keys, passwords, or credentials
